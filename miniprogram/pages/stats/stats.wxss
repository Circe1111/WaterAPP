.period-bar {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 10rpx;
}

.period-item {
  padding: 12rpx 40rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
}

.period-item.active {
  background: #4A90D9;
  color: #fff;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.stat-card {
  width: 48%;
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin: 1%;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #4A90D9;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.chart-canvas {
  width: 650rpx;
  height: 380rpx;
  margin: 0 auto;
}
