.tab-bar {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: #4A90D9;
  border-bottom-color: #4A90D9;
  font-weight: bold;
}

.friend-item {
  display: flex;
  align-items: center;
}

.friend-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  background: #e0e0e0;
}

.friend-info {
  flex: 1;
}

.friend-name {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
}

.friend-stats {
  font-size: 24rpx;
  color: #999;
}

.friend-arrow {
  color: #ccc;
  font-size: 32rpx;
}

.request-info {
  flex: 1;
  margin-bottom: 20rpx;
}

.request-name {
  font-weight: bold;
  font-size: 30rpx;
}

.request-text {
  color: #999;
  font-size: 26rpx;
  margin-left: 10rpx;
}

.btn-accept, .btn-add {
  background: #4A90D9 !important;
  color: #fff !important;
  border-radius: 8rpx;
}

.period-bar {
  display: flex;
  justify-content: center;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 10rpx;
}

.period-item {
  padding: 10rpx 30rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
}

.period-item.active {
  background: #4A90D9;
  color: #fff;
}

.rank-item {
  display: flex;
  align-items: center;
}

.rank-num {
  width: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #ff9500;
}

.rank-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin: 0 20rpx;
  background: #e0e0e0;
}

.rank-name {
  flex: 1;
  font-size: 30rpx;
}

.rank-amount {
  font-size: 32rpx;
  font-weight: bold;
  color: #4A90D9;
}

.search-box {
  display: flex;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.btn-search {
  margin-left: 20rpx;
  background: #4A90D9 !important;
  color: #fff !important;
  border-radius: 8rpx;
}
