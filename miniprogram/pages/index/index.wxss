.progress-card {
  text-align: center;
  padding: 40rpx 30rpx;
}

.progress-header {
  margin-bottom: 20rpx;
}

.progress-bar {
  height: 20rpx;
  background: #e8edf2;
  border-radius: 10rpx;
  overflow: hidden;
  margin: 20rpx 0;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90D9, #67B8F7);
  border-radius: 10rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  display: block;
}

.cup-grid {
  display: flex;
  justify-content: space-between;
}

.cup-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f0f7ff;
  min-width: 130rpx;
}

.cup-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.cup-label {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.cup-amount {
  font-size: 22rpx;
  color: #4A90D9;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-left {
  display: flex;
  flex-direction: column;
}

.record-amount {
  font-size: 30rpx;
  color: #4A90D9;
  font-weight: bold;
}

.record-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.record-delete {
  color: #ff4d4d;
  font-size: 26rpx;
  padding: 8rpx 16rpx;
}

.empty-tip {
  text-align: center;
  color: #ccc;
  padding: 40rpx 0;
  font-size: 28rpx;
}
