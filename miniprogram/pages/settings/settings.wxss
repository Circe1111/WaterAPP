.goal-row {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
}

.goal-input {
  flex: 1;
  font-size: 40rpx;
  font-weight: bold;
  color: #4A90D9;
  border-bottom: 2rpx solid #e0e0e0;
  padding: 10rpx 0;
}

.goal-unit {
  font-size: 30rpx;
  color: #999;
  margin: 0 20rpx;
}

.btn-save {
  background: #4A90D9 !important;
  color: #fff !important;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.reminder-switch {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.time-grid {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.time-item {
  padding: 12rpx 24rpx;
  margin: 6rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.time-item.selected {
  background: #4A90D9;
  color: #fff;
}
