.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.history-date {
  font-size: 32rpx;
  font-weight: bold;
}

.history-total {
  font-size: 36rpx;
  color: #4A90D9;
  font-weight: bold;
}

.history-detail {
  padding-left: 20rpx;
}

.detail-item {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.detail-time {
  font-size: 26rpx;
  color: #999;
}

.detail-amount {
  font-size: 28rpx;
  color: #4A90D9;
}

.loading-tip {
  text-align: center;
  color: #999;
  padding: 30rpx 0;
  font-size: 26rpx;
}
